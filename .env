# Laravel API base — used by lib/api/bkash.ts to talk to the Laravel backend.
# Leave empty or comment out to use mock payment API (prototype mode).
NEXT_PUBLIC_LARAVEL_API_URL=http://localhost:8000

# Optional — point to a remote API for marketing copy. Defaults to local mock JSON.
# NEXT_PUBLIC_API_BASE_URL=https://api.fcommerce.bd
# NEXT_PUBLIC_USE_MOCK_API=false
