APP_NAME=FcommerceBD
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Where to redirect users after payment success/failure
FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=fcommerce
DB_USERNAME=root
DB_PASSWORD=

# Sanctum SPA auth — set this to your Next.js host(s)
SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=localhost

# ─── bKash Tokenized Checkout (sandbox creds — replace for production) ───
BKASH_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta
BKASH_APP_KEY=4f6o0cjiki2rfm34kfdadl1eqq
BKASH_APP_SECRET=2sl2qfu1u26lh1usbu450dnonpcnaur92u3lf6m74q72m9k7g3p
BKASH_USERNAME=sandboxTokenizedUser02
BKASH_PASSWORD=sandboxTokenizedUser02@12345

# Optional — if bKash provisions webhook signing for your account
BKASH_WEBHOOK_SECRET=

# Where bKash will redirect the user after the wallet OTP step.
# Must be publicly reachable (use ngrok in dev: e.g. https://abc123.ngrok-free.app/api/bkash/callback)
BKASH_CALLBACK_URL=${APP_URL}/api/bkash/callback

# ─── Facebook Page integration ───
# Create an app at https://developers.facebook.com/apps and add the
# "Facebook Login" product. The redirect URI MUST be added to its
# "Valid OAuth Redirect URIs" list and must match FACEBOOK_REDIRECT_URI exactly.
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_GRAPH_VERSION=v21.0
FACEBOOK_REDIRECT_URI=${APP_URL}/api/facebook/callback
FACEBOOK_FRONTEND_SUCCESS_URL=${FRONTEND_URL}/integrations?fb=connected
FACEBOOK_FRONTEND_FAILURE_URL=${FRONTEND_URL}/integrations?fb=failed
FACEBOOK_MAX_POSTS_PER_DAY=25
FACEBOOK_MIN_GAP_SECONDS=300

# Queue driver — Facebook publishing runs through queues. Use "redis" or "database"
# in production; "sync" works in dev but blocks the request.
QUEUE_CONNECTION=database

# ─── AI provider for caption generation (optional) ───
# stub      = deterministic local generator (no key required)
# anthropic = Claude (set AI_API_KEY to your Anthropic key, AI_MODEL e.g. claude-haiku-4-5)
# openai    = OpenAI (set AI_API_KEY to your OpenAI key, AI_MODEL e.g. gpt-4o-mini)
AI_PROVIDER=stub
AI_API_KEY=
AI_MODEL=claude-haiku-4-5

# ─── Steadfast Courier ───
# Per-user keys are stored encrypted in the steadfast_credentials table.
# This env var only configures the API base URL (almost never overridden).
STEADFAST_BASE_URL=https://portal.packzy.com/api/v1

# ─── SMS provider (subscription reminders + future campaign sends) ───
# Drivers: "log" (writes to storage/logs/sms.log, no real SMS — safe for dev)
#          "greenweb" (production driver — requires GREENWEB_SMS_TOKEN)
SMS_DRIVER=log
# bdbulksms.net (Greenweb) — the driver appends ?json automatically.
GREENWEB_SMS_ENDPOINT=https://api.bdbulksms.net/api.php
GREENWEB_SMS_TOKEN=
SMS_BRAND_PREFIX=FcommerceBD

# ─── Outbound email (subscription reminders) ───
# In dev set MAIL_MAILER=log to write to storage/logs/laravel.log without sending.
# In prod use smtp/ses/resend/etc.
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@fcommerce.bd
MAIL_FROM_NAME="FcommerceBD"
